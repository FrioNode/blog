<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/navbar') %>

  <main>
    <section class="hero">
      <div class="hero__tag">[ building in public ]</div>
      <h1 class="hero__title">solo dev.<br/>real problems.<br/><span class="accent">no shortcuts.</span></h1>
      <p class="hero__sub">
        I'm a developer based in Nairobi building a tech company from scratch —
        one commit at a time. This blog is the unfiltered diary of that journey.
        The wins, the bugs, the doubts, everything.
      </p>
      <div class="hero__cta">
        <a href="/blog" class="btn">read the diary →</a>
        <a href="https://github.com/frionode/mood" target="_blank" class="btn btn--ghost">watch me build ↗</a>
      </div>
      <div class="hero__status">
        <span class="dot"></span> currently building: <strong>MoodBoard Live</strong> — a real-time anonymous mood tracker
      </div>
    </section>

    <section class="posts">
      <h2 class="section__title">latest entries</h2>
      <div class="posts__grid">
        <% posts.forEach(post => { %>
        <article class="post__card">
          <span class="post__tag"><%= post.tag %></span>
          <h3 class="post__title"><%= post.title %></h3>
          <p class="post__excerpt"><%= post.excerpt %></p>
          <div class="post__meta">
            <span><%= post.date %></span>
            <a href="/blog/<%= post.slug %>" class="post__read">read →</a>
          </div>
        </article>
        <% }) %>

        <!-- Coming soon placeholder -->
        <article class="post__card post__card--muted">
          <span class="post__tag">Dev Log</span>
          <h3 class="post__title">Day 1: Setting Up The Stack</h3>
          <p class="post__excerpt">Coming soon — first real dev log. Project structure, WebSocket handshake, and why I chose Postgres over MongoDB.</p>
          <div class="post__meta">
            <span>coming soon</span>
          </div>
        </article>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
